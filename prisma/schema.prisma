generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String
  password  String
  role      Role          @default(AGENT)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  orders      Order[]       @relation("AssignedTo")
  logs        ActivityLog[]
  orderNotes  OrderNote[]
}

model Store {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  domain           String?
  domainStatus     DomainStatus  @default(PENDING)
  niche            String
  language         StoreLanguage @default(FR)
  active           Boolean       @default(true)
  primaryColor     String        @default("#111827")
  logoText         String?
  logoUrl          String?
  heroImageUrl     String?
  heroTitle        String?
  heroSubtitle     String?
  slogan           String?
  currency         String        @default("CAD")
  useMainStripeKey Boolean       @default(true)
  stripeKey        String?
  paymentMethods   String[]      @default(["card"])
  emailTemplates   Json?
  createdAt        DateTime      @default(now())
  products         Product[]
  orders           Order[]
}

model Product {
  id            String      @id @default(cuid())
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  name          String
  nameFr        String
  description   String
  descriptionFr String
  price         Float
  cost          Float
  images        String[]
  supplier      Supplier
  supplierSku   String
  active        Boolean     @default(true)
  featured      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  orderItems    OrderItem[]
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String      @unique
  storeId            String
  store              Store       @relation(fields: [storeId], references: [id])
  assignedToId       String?
  assignedTo         User?       @relation("AssignedTo", fields: [assignedToId], references: [id])
  status             OrderStatus @default(PENDING)
  customerName       String
  customerEmail      String
  customerPhone      String?
  shippingAddress    Json
  items              OrderItem[]
  totalAmount        Float
  currency           String      @default("CAD")
  stripePaymentId    String?
  supplierOrderId    String?
  trackingNumber     String?
  trackingUrl        String?
  trackingCarrier    String?
  notes              String?
  cancellationReason String?
  expectedDeliveryAt DateTime?
  dispatchedAt       DateTime?
  cancelledAt        DateTime?
  refundedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  trackingEvents     TrackingEvent[]
  orderNotes         OrderNote[]
  statusHistory      OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model SupplierConnection {
  id          String    @id @default(cuid())
  supplier    Supplier  @unique
  apiKey      String?
  apiSecret   String?
  connected   Boolean   @default(false)
  lastSyncAt  DateTime?
  lastError   String?
  updatedAt   DateTime  @updatedAt
}

model TrackingEvent {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  status     String
  location   String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  tag        Int?
  source     String?  @default("manual")
}

model AppSettings {
  id                    String   @id @default(cuid())
  companyName           String   @default("VNK Automatisation")
  defaultLanguage       String   @default("fr")
  resendApiKey          String?
  fromEmail             String?
  stripeSecretKey       String?
  seventeenTrackKey     String?
  trackingWebhookSecret String?
  slaHours              Int      @default(48)
  updatedAt             DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED_TO_SUPPLIER
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  REFUNDED
}

enum Supplier {
  CJ_DROPSHIPPING
  ALIEXPRESS
  ZENDROP
  PRINTFUL
  MANUAL
}

enum DomainStatus {
  PENDING
  ACTIVE
  ERROR
}

enum StoreLanguage {
  FR
  EN
  BILINGUAL
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  fromStatus String?
  toStatus   String
  userId     String?
  note       String?
  createdAt  DateTime @default(now())
}
